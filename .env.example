PORT=8070
HOST=0.0.0.0
NODE_ENV=production
TRUST_PROXY=true
# Optional public base URL override. Leave empty to auto-detect from request host/proxy headers.
APP_BASE_URL=
SESSION_COOKIE_MAX_AGE_DAYS=30
REQUEST_JSON_LIMIT=80mb
MONGODB_MAIN_DB_URL=
MONGODB_MESSAGE_DB_URL=
# Optional DB name overrides. If unset, the name in URI path is used, falling back to defaults.
MONGODB_MAIN_DB_NAME=achat_main
MONGODB_MESSAGE_DB_NAME=achat_messages
CATBOX_USER_HASH=
CATBOX_MAX_FILE_BYTES=12582912
CATBOX_MAX_FILES_PER_UPLOAD=4
